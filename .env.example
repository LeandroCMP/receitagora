# Environment configuration for Receitagora
# Rename this file to `.env` and fill in your own credentials. Do not commit your
# personal secrets to version control.

# OpenAI API settings (opcional, mas recomendado para usar a IA)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
